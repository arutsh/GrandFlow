ENV=development
DEBUG=True
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=grandflow-db
POSTGRES_PORT=5432
users_database_url=postgresql://postgres:postgres@grandflow-db:5432/grandflow_users
REDIS_URL=redis://grandflow-redis:6380/0
RABBITMQ_URL=amqp://guest:guest@grandflow-rabbitmq:5672/
RABBITMQ_EXCHANGE=grandflow.events
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001,http://localhost:5173
